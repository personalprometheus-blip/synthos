synthos_build/.DS_Store
.DS_Store

# Python bytecode caches
__pycache__/
*.pyc

# Claude worktrees (per-session scratch)
.claude/worktrees/
synthos_build/.known_good/

# Runtime state — regenerated by services, must not churn in git
synthos_build/logs/scheduler_history.json
synthos_build/logs/*.pid
synthos_build/.trade_daemon_heartbeat
synthos_build/logs/daily_master/
synthos_build/logs/tier_readout/
.obsidian/
.venv-*

# Customer data — NEVER commit. Pulled locally for dev iteration only.
# Each Pi maintains its own data dir; committing would leak encrypted PII.
synthos_build/data/customers/
synthos_build/data/auth.db
synthos_build/data/auth.db-journal
synthos_build/data/auth.db-wal
synthos_build/data/auth.db-shm

# Ad-hoc PDF / analysis reports written locally. Keep out of git so
# generated artifacts don't churn history. The one PDF already in the
# tree (reports/PnL_Deep_Dive_2026-04-24.pdf, committed in 5f505a9)
# stays for reference; future reports land in the same folder but
# are excluded from commits.
reports/*.pdf
reports/*.csv
reports/*.html

synthos_build/.DS_Store
.DS_Store

# Python bytecode caches
__pycache__/
*.pyc

# Claude worktrees (per-session scratch)
.claude/worktrees/
synthos_build/.known_good/

# Runtime state — regenerated by services, must not churn in git
synthos_build/logs/scheduler_history.json
synthos_build/logs/*.pid
synthos_build/logs/*.bak.*
synthos_build/logs/*.bak.*.gz
synthos_build/.trade_daemon_heartbeat
synthos_build/.trade_daemon.pid
synthos_build/.agent_running
synthos_build/logs/daily_master/
synthos_build/logs/tier_readout/
.obsidian/
.venv-*

# Customer data — NEVER commit. Pulled locally for dev iteration only.
# Each Pi maintains its own data dir; committing would leak encrypted PII.
synthos_build/data/customers/
synthos_build/data/auth.db
synthos_build/data/auth.db-journal
synthos_build/data/auth.db-wal
synthos_build/data/auth.db-shm

# Migration tool backups — runtime-only artifacts (pre-migration SQLite
# snapshots + dedup/retag CSVs). Generated by tools/cleanup_*.py,
# tools/migrate_owner_to_shared_db.py, etc. Can be hundreds of MB on
# pi5; never appears on Mac dev tree.
synthos_build/data/migrations/

# Ad-hoc PDF / analysis reports written locally. Keep out of git so
# generated artifacts don't churn history. The one PDF already in the
# tree (reports/PnL_Deep_Dive_2026-04-24.pdf, committed in 5f505a9)
# stays for reference; future reports land in the same folder but
# are excluded from commits.
reports/*.pdf
reports/*.csv
reports/*.html

# Operator scratchpads — handoff/audit notes from ad-hoc Claude sessions.
# Useful as ephemeral context; not deployable, not authoritative. Anything
# worth keeping should graduate into documentation/ or a memory file.
.claude/*.md

# WIP onboarding screenshots — operator captures these during signup-flow
# documentation sweeps. Un-gitignore (or commit with -f) when the set is
# complete and ready to publish as part of onboarding docs.
synthos_build/static/setup/

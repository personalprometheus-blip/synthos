# Python
__pycache__/
*.pyc
*.pyo
src/__pycache__/

# Database files
*.db
*.db-shm
*.db-wal

# Environment / secrets
.env
company.env
*.env

# Install state
.install_complete
.install_progress.json

# Logs
logs/*.log
logs/archive/
logs/logic_audits/
logs/crash_reports/
src/logs/

# Runtime data
data/suggestions.json

# Runtime state
.kill_switch
.pending_approvals.json
signals_backup.db
.market_daemon.pid
.market_daemon_heartbeat
.wave_override
# .known_good/ is intentionally tracked — it's the watchdog's
# rollback snapshot and we want version history on it.

# Ad-hoc patch snapshots — one-shot *.py.pre_*_bak / *.py.bak_* files
# produced by /tmp patch scripts during early development. Not source.
*_bak
*.bak
*.bak_*

# Rolling automated backups (separate disaster-recovery artifacts —
# not committed; migrated out-of-band).
backups/
